def benchmark_script(script_path, iterations=3):
    """Benchmark a single script."""
    times = []
    
    for i in range(iterations):
        start = time.perf_counter()
        try:
            with open(script_path) as f:
                exec(f.read())
        except Exception as e:
            print(f"  Error: {e}")
            return None
        end = time.perf_counter()
        times.append(end - start)
    
    avg_time = sum(times) / len(times)
    return avg_time

def main():
    cv_steps_path = Path(__file__).parent / "CV_steps"
    
    if not cv_steps_path.exists():
        print(f"CV_steps directory not found at {cv_steps_path}")
        return
    
    scripts = sorted(cv_steps_path.glob("*.py"))
    
    print("Benchmarking CV_steps scripts...\n")
    results = []
    
    for script in scripts:
        print(f"Testing {script.name}...", end=" ", flush=True)
        avg_time = benchmark_script(script)
        if avg_time:
            print(f"{avg_time:.4f}s")
            results.append((script.name, avg_time))
    
    print("\n--- Results ---")
    for name, time_taken in sorted(results, key=lambda x: x[1]):
        print(f"{name}: {time_taken:.4f}s")

if __name__ == "__main__":
    main()